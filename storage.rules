rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all media
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Doctor images
    match /doctors/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Gallery media (images & videos)
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 100 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
    }

    // Blog images
    match /blogs/{imageId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Speciality media (images & videos)
    match /specialities/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
    }
  }
}
